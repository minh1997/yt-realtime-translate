{
  "name": "youtube-asr-sidepanel",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "MV3 Chrome extension that captures YouTube tab audio and prepares it for realtime ASR, displayed in a React side panel.",
  "scripts": {
    "dev": "concurrently \"npm run dev:whisper\" \"npm run dev:extension\"",
    "dev:extension": "vite",
    "build": "vite build",
    "build:extension": "vite build",
    "dev:whisper": "node scripts/dev-whisper.mjs"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.0.0",
    "vite": "^5.4.11",
    "vosk-browser": "^0.0.8"
  }
}
